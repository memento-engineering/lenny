{
  // VS Code tasks for the lenny workspace.
  //
  // The DevTools extension bundle is rebuild-on-demand (per lenny-1l8):
  // source lives in packages/exploration_devtools/, but the artifact
  // DevTools actually serves is the compiled web build copied into
  // packages/exploration_flutter/extension/devtools/build/. Without
  // a fresh rebuild after touching exploration_devtools source, the
  // dogfood target loads a stale panel.
  //
  // The "Build DevTools Extension" task wraps tool/build_devtools_extension.sh
  // and is referenced as preLaunchTask on the dogfood-relevant sample_app
  // configs in launch.json so the panel a developer sees in Chrome always
  // matches the source in their checkout.
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build DevTools Extension",
      "type": "shell",
      "command": "${workspaceFolder}/tool/build_devtools_extension.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
