{
  // Launch configurations for the lenny workspace.
  //
  // Conventions:
  //   - All Flutter targets default to macOS (the only platform sample_app
  //     scaffolds for v1; see packages/leonard_flutter/example/sample_app/README.md).
  //   - Sample-app configs set `cwd` to the package so `flutter run` and the
  //     Dart-Code extension resolve the right `pubspec.yaml` from the workspace.
  //   - The "leonard_cli (attach to running app)" config prompts for a VM
  //     service URI — copy it from the Flutter run console after the app boots.
  //   - Compound "Sample app + leonard_cli" boots the app first; once it
  //     prints `Dart VM service is listening on ws://...`, paste that URI when
  //     the CLI prompts.
  //   - "leonard_devtools (standalone web)" runs the panel via the
  //     devtools_extensions simulated environment (Chrome web target, no
  //     bundle rebuild); use it for fast widget/layout iteration. The
  //     dogfood compound is the only path that exercises real DTD/VM.
  "version": "0.2.0",
  "inputs": [
    {
      "id": "vmServiceUri",
      "type": "promptString",
      "description": "Dart VM service URI from the running sample_app (ws://127.0.0.1:.../ws)",
      "default": "ws://127.0.0.1:0/ws"
    },
    {
      "id": "leonardGoal",
      "type": "promptString",
      "description": "Leonard goal (natural language)",
      "default": "Log in with demo@example.com/password, change the theme to dark, then log out."
    }
  ],
  "configurations": [
    {
      "name": "sample_app (debug)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/packages/leonard_flutter/example/sample_app",
      "flutterMode": "debug",
      // Rebuild the DevTools extension bundle before launching so the
      // panel served to Chrome always reflects the current source
      // (rebuild-on-demand, never commit).
      "preLaunchTask": "Build DevTools Extension",
      "presentation": {
        "group": "1_sample_app",
        "order": 1
      }
    },
    {
      "name": "sample_app (profile)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/packages/leonard_flutter/example/sample_app",
      "flutterMode": "profile",
      "preLaunchTask": "Build DevTools Extension",
      "presentation": {
        "group": "1_sample_app",
        "order": 2
      }
    },
    {
      "name": "sample_app (release)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/packages/leonard_flutter/example/sample_app",
      "flutterMode": "release",
      "presentation": {
        "group": "1_sample_app",
        "order": 3
      }
    },
    {
      "name": "sample_app: tests",
      "type": "dart",
      "request": "launch",
      "program": "test/",
      "cwd": "${workspaceFolder}/packages/leonard_flutter/example/sample_app",
      "presentation": {
        "group": "1_sample_app",
        "order": 4
      }
    },
    {
      "name": "leonard_cli (attach to running app)",
      "type": "dart",
      "request": "launch",
      "program": "bin/leonard_cli.dart",
      "cwd": "${workspaceFolder}/packages/leonard_cli",
      "args": [
        "--vm-uri",
        "${input:vmServiceUri}",
        "--goal",
        "${input:leonardGoal}",
        "--extensions",
        "router,riverpod,dio"
      ],
      "presentation": {
        "group": "2_leonard_cli",
        "order": 1
      }
    },
    {
      "name": "leonard_devtools (standalone web)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/packages/leonard_devtools",
      "deviceId": "chrome",
      // Runs the panel as a plain Flutter web app against the
      // devtools_extensions simulated environment (fake DTD + fake VM
      // service). NO preLaunchTask: this path deliberately skips the
      // bundle rebuild — Dart-Code attaches its own VM
      // service, so breakpoints in lib/** and hot reload on save work.
      // For the real DTD/VM handshake use the dogfood compound instead.
      "args": ["--dart-define=use_simulated_environment=true"],
      "presentation": {
        "group": "4_devtools",
        "order": 1
      }
    }
  ],
  "compounds": [
    {
      "name": "Dogfood: sample_app + leonard_cli",
      "configurations": [
        "sample_app (debug)",
        "leonard_cli (attach to running app)"
      ],
      "stopAll": true,
      "presentation": {
        "group": "3_dogfood",
        "order": 1
      }
    }
  ]
}
