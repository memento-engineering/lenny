.DS_Store

# .claude — track team-shared config (agents, skills, hooks), ignore runtime/personal
.claude/projects/
.claude/cache/
.claude/conversations/
.claude/local/
.claude/settings.local.json
.claude/*.local.json
.claude/scheduled_tasks.lock

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
/.worktrees/

# Dart / Flutter
.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
pubspec.lock
**/.idea/
**/*.iml

# Per-user Flutter DevTools enablement state (extensions: ... toggles).
# Regenerated locally; not a project default.
devtools_options.yaml

# leonard_cli trajectory output (local run artifacts, not source).
packages/leonard_cli/trajectories/

# Astro product site build artifacts (belt-and-braces with site/.gitignore).
site/node_modules/
site/dist/
site/.astro/

# Beads / Dolt files (added by bd init)
.beads/proxieddb/
lenny-whn/

# Gas City
.beads/*
!.beads/config.yaml
!.beads/metadata.json
!.beads/identity.toml

# Gas City factory committee — DERIVED artifacts composed by
# scripts/install-rig-committee.sh (the neutral factoryskills pack + the
# .gascity-pack Dart overlay). Source of truth is .gascity-pack/ (tracked); the
# composed copies are reproducible, so they are not committed. lenny's own
# skills (beads, debug-inference, harden, predictable-flutter) stay tracked.
.agents/agents/
.claude/agents/
.agents/skills/critique/
.agents/skills/deliberate/
.agents/skills/discover/
.agents/skills/factory/
.agents/skills/factoryskills/
.agents/skills/forge/
.agents/skills/land/
.agents/skills/marshal/
.agents/skills/merge/
.agents/skills/route/
.agents/skills/specify/
.claude/skills/critique/
.claude/skills/deliberate/
.claude/skills/discover/
.claude/skills/factory/
.claude/skills/factoryskills/
.claude/skills/forge/
.claude/skills/land/
.claude/skills/marshal/
.claude/skills/merge/
.claude/skills/route/
.claude/skills/specify/

# Local scratch / factory runtime state — not part of the repo
spikes/
.gc/
.factoryskills/sessions.jsonl
.beads/identity.toml

# Env files — never commit secrets
*.env
.env
