.DS_Store

# .claude — track team-shared config (agents, skills, hooks), ignore runtime/personal
.claude/projects/
.claude/cache/
.claude/conversations/
.claude/local/
.claude/settings.local.json
.claude/*.local.json
.claude/scheduled_tasks.lock

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
/.worktrees/

# Dart / Flutter
.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
pubspec.lock
**/.idea/
**/*.iml

# Per-user Flutter DevTools enablement state (extensions: ... toggles).
# Regenerated locally; not a project default.
devtools_options.yaml

# exploration_cli trajectory output (local run artifacts, not source).
packages/exploration_cli/trajectories/

# Astro product site build artifacts (belt-and-braces with site/.gitignore).
site/node_modules/
site/dist/
site/.astro/
