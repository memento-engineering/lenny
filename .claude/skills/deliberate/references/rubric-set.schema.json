{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://factoryskills/schemas/rubric-set.json",
  "title": "RubricSet",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "version", "rubrics"],
  "properties": {
    "name":    {"type": "string", "minLength": 1},
    "version": {"type": "integer", "minimum": 1},
    "rubrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "version"],
        "properties": {
          "name":    {"type": "string", "minLength": 1},
          "version": {"type": "integer", "minimum": 1}
        }
      }
    }
  }
}
